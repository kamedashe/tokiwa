# PostgreSQL — и локально, и в проде. Бесплатный тариф Neon или Supabase.
# Neon умеет ветки: удобно завести отдельную для разработки.
DATABASE_URL=""

# Защита POST /api/sync — без него ручку синхронизации дёрнет кто угодно.
# Сгенерировать: openssl rand -base64 32
SYNC_SECRET=""

# Vercel сам подставляет этот секрет в заголовок при вызове по крону.
# Задать в переменных окружения проекта на Vercel.
CRON_SECRET=""

# Auth.js. Секрет: openssl rand -base64 32
AUTH_SECRET=""

# Discord Developer Portal → OAuth2. В Redirects добавить:
#   http://localhost:3000/api/auth/callback/discord
#   https://<домен>/api/auth/callback/discord   — для прода
AUTH_DISCORD_ID=""
AUTH_DISCORD_SECRET=""

# Google Cloud Console → APIs & Services → Credentials → OAuth client ID
# (тип Web application). Биллинг подключать не нужно.
# В Authorized redirect URIs добавить:
#   http://localhost:3000/api/auth/callback/google
#   https://<домен>/api/auth/callback/google     — для прода
# В OAuth consent screen указать ссылку на https://<домен>/privacy —
# без неё приложение не выйдет из режима Testing (лимит 100 пользователей).
AUTH_GOOGLE_ID=""
AUTH_GOOGLE_SECRET=""

# Емейлы через запятую — получают роль admin при входе. Так назначается
# первый админ: в свежей БД пользователей нет и повысить некого.
ADMIN_EMAILS=""

# Партнёрские ссылки. Шаблон на каждый сервис, {url} заменяется на адрес
# страницы тайтла. Берётся в CPA-сети (Admitad, Actionpay) после подключения
# к программе сервиса. Не задано — ссылка остаётся обычной.
# AFFILIATE_OKKO="https://ad.admitad.com/g/xxxxxxxx/?ulp={url}"
# AFFILIATE_KINOPOISK=""
# AFFILIATE_MEGOGO=""
