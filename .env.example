# PostgreSQL — и локально, и в проде. Бесплатный тариф Neon или Supabase.
# Neon умеет ветки: удобно завести отдельную для разработки.
#
# Нужны ОБЕ строки, они отличаются только «-pooler» в имени хоста:
#   DATABASE_URL — пулерная, по ней ходит приложение
#   DIRECT_URL   — прямая, по ней идут миграции (через пулер они ломаются)
DATABASE_URL="postgresql://user:pass@ep-xxx-pooler.region.aws.neon.tech/dbname?sslmode=require"
DIRECT_URL="postgresql://user:pass@ep-xxx.region.aws.neon.tech/dbname?sslmode=require"

# Защита POST /api/sync — без него ручку синхронизации дёрнет кто угодно.
# Сгенерировать: openssl rand -base64 32
SYNC_SECRET=""

# Vercel сам подставляет этот секрет в заголовок при вызове по крону.
# Задать в переменных окружения проекта на Vercel.
CRON_SECRET=""

# Auth.js. Секрет: openssl rand -base64 32
AUTH_SECRET=""

# Discord Developer Portal → OAuth2. В Redirects добавить:
#   http://localhost:3000/api/auth/callback/discord
#   https://<домен>/api/auth/callback/discord   — для прода
AUTH_DISCORD_ID=""
AUTH_DISCORD_SECRET=""

# Google Cloud Console → APIs & Services → Credentials → OAuth client ID
# (тип Web application). Биллинг подключать не нужно.
# В Authorized redirect URIs добавить:
#   http://localhost:3000/api/auth/callback/google
#   https://<домен>/api/auth/callback/google     — для прода
# В OAuth consent screen указать ссылку на https://<домен>/privacy —
# без неё приложение не выйдет из режима Testing (лимит 100 пользователей).
AUTH_GOOGLE_ID=""
AUTH_GOOGLE_SECRET=""

# Донат в подвале сайта. Не задано ни одно значение — ссылки просто нет.
# Обе заданы — посетителю из RU/UA показываем Boosty, остальным Ko-fi.
# DONATE_BOOSTY_URL="https://boosty.to/<handle>"
# DONATE_KOFI_URL="https://ko-fi.com/<handle>"

# Telegram-бот уведомлений о новых сериях. Все три не заданы — фича спит:
# кнопки на сайте нет, рассылки нет, вебхук отвечает 401.
#
# 1. Создать бота у @BotFather (/newbot) — он выдаст токен и @имя.
# 2. Секрет вебхука: openssl rand -hex 32
# 3. Зарегистрировать вебхук (один раз, после деплоя с переменными):
#    curl "https://api.telegram.org/bot<ТОКЕН>/setWebhook?url=https://www.tokiwa.moe/api/telegram&secret_token=<СЕКРЕТ>"
# TELEGRAM_BOT_TOKEN=""
# TELEGRAM_BOT_USERNAME=""
# TELEGRAM_WEBHOOK_SECRET=""
